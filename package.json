{
  "name": "gonulkoprusu",
  "version": "1.0.0",
  "private": true,
  "description": "Gönül Köprüsü - topluluk yardımlaşma platformu (şikayet & bildirim akışı)",
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "npm run dev --workspace server",
    "dev:client": "npm run dev --workspace client",
    "build": "npm run build --workspace client",
    "lint": "npm run lint --workspace server && npm run lint --workspace client",
    "start": "npm run start --workspace server"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
